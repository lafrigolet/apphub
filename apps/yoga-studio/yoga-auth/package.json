{
  "name": "@yoga-studio/yoga-auth",
  "version": "0.1.0",
  "description": "YogaStudio auth microservice — registration, login, JWT",
  "private": true,
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "lint": "eslint src",
    "db:migrate": "node src/lib/migrate.js",
    "clean": "rm -rf coverage"
  },
  "dependencies": {
    "fastify": "^5.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "fastify-type-provider-zod": "^4.0.0",
    "fastify-plugin": "^5.0.0",
    "pg": "^8.12.0",
    "ioredis": "^5.4.1",
    "zod": "^3.23.0",
    "pino": "^9.3.0",
    "pino-pretty": "^11.2.0",
    "uuid": "^10.0.0",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "vitest": "^2.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "supertest": "^7.0.0"
  }
}
