# TPV Expo app — config para el cliente (todas las EXPO_PUBLIC_* se inlinean en build/Metro).
# Copia a `.env.local` y ajusta. NO commitear `.env.local` (ya está en .gitignore).

# Base del gateway NGINX del stack AppHub, tal como lo VE EL MÓVIL.
#   - Dispositivo físico por USB + `adb reverse tcp:8080 tcp:8080`:  http://localhost:8080   <-- tu caso
#   - Emulador Android:                                              http://10.0.2.2:8080
#   - Dispositivo físico por Wi-Fi/LAN:                              http://<IP-LAN-DEL-PC>:8080
EXPO_PUBLIC_API_BASE=http://localhost:8080

# Credenciales del cajero de prueba (seed: apps/tpv/seed.sql). Login silencioso.
EXPO_PUBLIC_DEV_EMAIL=cajero@tpv.local
EXPO_PUBLIC_DEV_PASSWORD=tpv1234
