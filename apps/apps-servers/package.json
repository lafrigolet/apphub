{
  "name": "@apphub/apps-servers",
  "version": "0.1.0",
  "description": "Apps-servers monolith — orchestrator hosting every app-specific server (aikikan, aulavera, …) as modules with per-app scoped guards (ADR 018)",
  "private": true,
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "test:unit": "vitest run --passWithNoTests",
    "lint": "eslint src",
    "clean": "rm -rf coverage"
  },
  "dependencies": {
    "@apphub/platform-sdk": "workspace:*",
    "@aikikan/aikikan-server": "workspace:*",
    "@aulavera/aulavera-server": "workspace:*",
    "fastify": "^4.28.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/sensible": "^5.6.0",
    "pg": "^8.12.0",
    "ioredis": "^5.4.1",
    "zod": "^3.23.8",
    "pino": "^9.3.0",
    "pino-pretty": "^11.2.0"
  },
  "devDependencies": {
    "vitest": "^2.0.0"
  }
}
