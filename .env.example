# ============================================================
# SplitPay Platform — Environment Variables
# Copy to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Infrastructure ───────────────────────────────────────────
DATABASE_URL=postgresql://splitpay:splitpay@localhost:5432/splitpay
REDIS_URL=redis://localhost:6379

# ── split-payments service ───────────────────────────────────
# Stripe test keys: https://dashboard.stripe.com/test/apikeys
PAYMENTS_STRIPE_SECRET_KEY=sk_test_replace_me
PAYMENTS_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Get from: stripe listen --forward-to localhost:3001/v1/webhooks/stripe
PAYMENTS_STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Platform Stripe Connect account ID (your own Connect platform account)
PAYMENTS_STRIPE_PLATFORM_ACCOUNT_ID=acct_replace_me

# Port the service listens on
PAYMENTS_PORT=3001

# JWT secret shared between services (use a long random string in production)
JWT_SECRET=change_me_in_production_use_openssl_rand_hex_64

# Node environment: development | test | production
NODE_ENV=development

# Log level: debug | info | warn | error
LOG_LEVEL=debug

# ── YogaStudio services ──────────────────────────────────────────
# Shared JWT secret for all yoga microservices (min 32 chars)
YOGA_JWT_SECRET=change_me_in_production_use_openssl_rand_hex_64

# Stripe keys for yoga-payments service
YOGA_STRIPE_SECRET_KEY=sk_test_replace_me
YOGA_STRIPE_WEBHOOK_SECRET=whsec_replace_me

# SendGrid for yoga-notifications service
YOGA_SENDGRID_API_KEY=SG.replace_me
YOGA_SENDGRID_FROM_EMAIL=noreply@yogastudio.com

# Tenant identity for this deployment (each studio instance has its own UUID)
YOGA_TENANT_ID=replace_me_with_uuid
YOGA_SUB_TENANT_ID=    # optional — leave blank for single-level tenancy

# Cron DB connection (svc_yoga_cron role has BYPASSRLS for cross-tenant background jobs)
YOGA_CRON_DATABASE_URL=postgresql://svc_yoga_cron:yoga_cron_secret@localhost:5432/splitpay

# Service ports
YOGA_AUTH_PORT=3010
YOGA_USERS_PORT=3011
YOGA_CLASSES_PORT=3012
YOGA_BOOKINGS_PORT=3013
YOGA_BONUSES_PORT=3014
YOGA_PAYMENTS_PORT=3015
YOGA_NOTIFICATIONS_PORT=3016
YOGA_REPORTING_PORT=3017
