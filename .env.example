# ============================================================
# SplitPay Platform — Environment Variables
# Copy to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Infrastructure ───────────────────────────────────────────
DATABASE_URL=postgresql://splitpay:splitpay@localhost:5432/splitpay
REDIS_URL=redis://localhost:6379

# ── split-payments service ───────────────────────────────────
# Stripe test keys: https://dashboard.stripe.com/test/apikeys
PAYMENTS_STRIPE_SECRET_KEY=sk_test_replace_me
PAYMENTS_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Get from: stripe listen --forward-to localhost:3001/v1/webhooks/stripe
PAYMENTS_STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Platform Stripe Connect account ID (your own Connect platform account)
PAYMENTS_STRIPE_PLATFORM_ACCOUNT_ID=acct_replace_me

# Port the service listens on
PAYMENTS_PORT=3001

# JWT secret shared between services (use a long random string in production)
JWT_SECRET=change_me_in_production_use_openssl_rand_hex_64

# Node environment: development | test | production
NODE_ENV=development

# Log level: debug | info | warn | error
LOG_LEVEL=debug
