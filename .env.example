# ============================================================
# AppHub Platform — Environment Variables
# Copy to .env and fill in your values.
# NEVER commit .env to version control.
#
# Secrets for Stripe, OAuth providers (Google/Facebook), Resend,
# and S3 access keys are NOT here — they live encrypted at rest in
# the database (platform_*/config|settings|oauth_providers tables)
# and are configured at runtime via /v1/<module>/admin endpoints
# (super_admin / staff role required). Only bootstrap secrets and
# infrastructure-level config remain in this file.
# ============================================================

# ── Infrastructure ───────────────────────────────────────────
DATABASE_URL=postgresql://splitpay:splitpay@localhost:5432/splitpay
REDIS_URL=redis://localhost:6379
NODE_ENV=development
LOG_LEVEL=debug

# ── Platform Services ────────────────────────────────────────

# Shared JWT secret for ALL platform services and app services (min 32 chars)
# Generate with: openssl rand -hex 64
PLATFORM_JWT_SECRET=change_me_in_production_use_openssl_rand_hex_64

# Master key for AES-256-GCM at-rest encryption of module config secrets
# (Stripe keys, OAuth client_secret, Resend API keys, S3 access keys
# stored in platform_*/config tables). Must be exactly 32 bytes hex.
# Generate with: openssl rand -hex 32
PLATFORM_CONFIG_ENCRYPTION_KEY=change_me_run_openssl_rand_hex_32

# ── Per-service DB roles (schema-isolated runtime connections) ──
# Each service connects as its own role — scoped to its schema only
PLATFORM_AUTH_DATABASE_URL=postgresql://svc_platform_auth:platform_auth_secret@localhost:5432/splitpay
PLATFORM_NOTIFICATIONS_DATABASE_URL=postgresql://svc_platform_notifications:platform_notifications_secret@localhost:5432/splitpay
# Superuser — used only by migrate.js for DDL (CREATE TABLE etc.)
MIGRATION_DATABASE_URL=postgresql://splitpay:splitpay@localhost:5432/splitpay

# ── Platform-restaurant module roles (in-process modules of platform-restaurant) ──
SVC_PLATFORM_MENU_DB_PASSWORD=platform_menu_secret
SVC_PLATFORM_RESERVATIONS_DB_PASSWORD=platform_reservations_secret
SVC_PLATFORM_FLOOR_PLAN_DB_PASSWORD=platform_floor_plan_secret
SVC_PLATFORM_KDS_DB_PASSWORD=platform_kds_secret
SVC_PLATFORM_POS_DB_PASSWORD=platform_pos_secret
SVC_PLATFORM_DELIVERY_DISPATCH_DB_PASSWORD=platform_delivery_dispatch_secret

# ── Platform-appointments module roles (in-process modules of platform-appointments) ──
SVC_PLATFORM_SERVICES_DB_PASSWORD=platform_services_secret
SVC_PLATFORM_RESOURCES_DB_PASSWORD=platform_resources_secret
SVC_PLATFORM_BOOKINGS_DB_PASSWORD=platform_bookings_secret
SVC_PLATFORM_AVAILABILITY_DB_PASSWORD=platform_availability_secret
SVC_PLATFORM_INTAKE_FORMS_DB_PASSWORD=platform_intake_forms_secret
SVC_PLATFORM_TELEHEALTH_DB_PASSWORD=platform_telehealth_secret
SVC_PLATFORM_PACKAGES_DB_PASSWORD=platform_packages_secret
SVC_PLATFORM_PRACTITIONER_PAYOUTS_DB_PASSWORD=platform_practitioner_payouts_secret

# ── Platform-scheduler (cron runner) ─────────────────────────────────
SVC_PLATFORM_SCHEDULER_DB_PASSWORD=platform_scheduler_secret
# Optional: per-job feature flags (default: true)
# JOB_AVAILABILITY_HOLD_PURGE_ENABLED=true
# JOB_BOOKING_REMINDERS_ENABLED=true
# JOB_BOOKING_RECURRENCE_EXPANDER_ENABLED=true
# JOB_RESERVATION_REMINDERS_ENABLED=true
# JOB_PACKAGE_EXPIRY_WARNING_ENABLED=true
# JOB_PACKAGE_EXPIRY_TRANSITION_ENABLED=true
# JOB_PRACTITIONER_PAYOUT_CLOSE_ENABLED=true
# JOB_DISPUTE_SLA_ENABLED=true
# JOB_BASKET_ABANDONED_ENABLED=true
# JOB_STORAGE_ORPHAN_PURGE_ENABLED=true
# JOB_STORAGE_RETENTION_PURGE_ENABLED=true
# Optional: inbox for SLA-breach notifications
# STAFF_OPS_EMAIL=ops@hulkstein.local

# ── Object storage — bootstrap only ──────────────────────────────────
# Root credentials for the MinIO container itself (dev only).
# The bucket name, region, endpoint and S3 access keys consumed by the
# platform-storage module live in platform_storage.settings and are
# configured via /v1/storage/admin/settings.
MINIO_ROOT_USER=apphub
MINIO_ROOT_PASSWORD=apphub_minio_secret
SVC_PLATFORM_STORAGE_DB_PASSWORD=platform_storage_secret
SVC_PLATFORM_LEADS_DB_PASSWORD=platform_leads_secret
SVC_PLATFORM_DONATIONS_DB_PASSWORD=platform_donations_secret
SVC_PLATFORM_INQUIRIES_DB_PASSWORD=platform_inquiries_secret
SVC_PLATFORM_VERIFACTU_DB_PASSWORD=platform_verifactu_secret

# ── Aikikan app ──────────────────────────────────────────────
AIKIKAN_TENANT_ID=replace_me_with_uuid

# ── Local dev: add these entries to /etc/hosts ───────────────
# 127.0.0.1  hulkstein.local
# 127.0.0.1  splitpay.hulkstein.local
