# ============================================================
# AppHub Platform — Environment Variables
# Copy to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Infrastructure ───────────────────────────────────────────
DATABASE_URL=postgresql://splitpay:splitpay@localhost:5432/splitpay
REDIS_URL=redis://localhost:6379
NODE_ENV=development
LOG_LEVEL=debug

# ── Platform Services ────────────────────────────────────────

# Shared JWT secret for ALL platform services and app services (min 32 chars)
# Generate with: openssl rand -hex 64
PLATFORM_JWT_SECRET=change_me_in_production_use_openssl_rand_hex_64

# Platform Stripe gateway (used by platform-payments service)
PLATFORM_STRIPE_SECRET_KEY=sk_test_replace_me
PLATFORM_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
PLATFORM_STRIPE_WEBHOOK_SECRET=whsec_replace_me
PLATFORM_STRIPE_PLATFORM_ACCOUNT_ID=acct_replace_me

# Platform notifications (used by platform-notifications service)
SENDGRID_API_KEY=SG.replace_me
SENDGRID_FROM_EMAIL=noreply@apphub.com

# ── Split Pay app (apps/split-pay/) ──────────────────────────
# Stripe Connect keys for the Split Pay app (splitpay-core, port 3020)
PAYMENTS_STRIPE_SECRET_KEY=sk_test_replace_me
PAYMENTS_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
PAYMENTS_STRIPE_WEBHOOK_SECRET=whsec_replace_me
PAYMENTS_STRIPE_PLATFORM_ACCOUNT_ID=acct_replace_me

# ── YogaStudio app (apps/yoga-studio/) ──────────────────────────
# Shared JWT secret for yoga microservices (kept during migration to platform-auth)
YOGA_JWT_SECRET=change_me_in_production_use_openssl_rand_hex_64

# Stripe keys for yoga-payments service (kept during migration to platform-payments)
YOGA_STRIPE_SECRET_KEY=sk_test_replace_me
YOGA_STRIPE_WEBHOOK_SECRET=whsec_replace_me

# SendGrid for yoga-notifications service (kept during migration to platform-notifications)
YOGA_SENDGRID_API_KEY=SG.replace_me
YOGA_SENDGRID_FROM_EMAIL=noreply@yogastudio.com

# Tenant identity for the yoga studio deployment
YOGA_TENANT_ID=replace_me_with_uuid
YOGA_SUB_TENANT_ID=    # optional — leave blank for single-level tenancy

# Cron DB connection (BYPASSRLS role for background jobs)
YOGA_CRON_DATABASE_URL=postgresql://svc_yoga_cron:yoga_cron_secret@localhost:5432/splitpay

# ── Local dev: add these entries to /etc/hosts ───────────────
# 127.0.0.1  apphub.local
# 127.0.0.1  yoga.apphub.local
# 127.0.0.1  splitpay.apphub.local
