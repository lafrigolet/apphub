{
  "name": "@apphub/platform-marketplace",
  "version": "0.1.0",
  "description": "Platform-marketplace monolith — orchestrator for marketplace modules (orders, inventory, reviews, messaging, shipping, disputes)",
  "private": true,
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "test:unit": "vitest run --passWithNoTests",
    "lint": "eslint src",
    "clean": "rm -rf coverage"
  },
  "dependencies": {
    "@apphub/platform-sdk": "workspace:*",
    "@apphub/platform-orders": "workspace:*",
    "@apphub/platform-inventory": "workspace:*",
    "@apphub/platform-reviews": "workspace:*",
    "@apphub/platform-messaging": "workspace:*",
    "@apphub/platform-shipping": "workspace:*",
    "@apphub/platform-disputes": "workspace:*",
    "fastify": "^5.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "fastify-type-provider-zod": "^4.0.0",
    "pg": "^8.12.0",
    "ioredis": "^5.4.1",
    "zod": "^3.23.0",
    "pino": "^9.3.0",
    "pino-pretty": "^11.2.0"
  },
  "devDependencies": {
    "vitest": "^2.0.0"
  }
}
