{
  "name": "@apphub/platform-storage",
  "version": "0.1.0",
  "description": "Storage module — presigned PUT/GET for S3-compatible buckets, with metadata table, MIME/size enforcement, retention policy, and audit events",
  "private": true,
  "type": "module",
  "main": "src/index.js",
  "exports": { ".": "./src/index.js" },
  "scripts": {
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "node ../../scripts/integration-or-skip.mjs",
    "lint": "eslint src",
    "db:migrate": "node src/lib/migrate.js"
  },
  "dependencies": {
    "@apphub/platform-sdk": "workspace:*",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.0",
    "fastify-type-provider-zod": "^4.0.0",
    "pg": "^8.12.0",
    "ioredis": "^5.4.1",
    "zod": "^3.23.0",
    "pino": "^9.3.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "vitest": "^2.0.0",
    "@vitest/coverage-v8": "^2.0.0"
  }
}
