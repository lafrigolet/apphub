{
  "name": "@apphub/platform-tenant-config",
  "version": "0.1.0",
  "description": "Platform tenant-config service — app/tenant registry (all apps)",
  "private": true,
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "test:unit": "vitest run --passWithNoTests",
    "test:integration": "vitest run --config vitest.integration.config.js",
