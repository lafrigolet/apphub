{
  "name": "@apphub/platform-scheduler",
  "version": "0.1.0",
  "description": "Platform-scheduler — centralized cron runner for all 4 monoliths (booking reminders, hold purge, package expiry, payout close, dispute SLA, abandoned cart, recurrence expansion)",
  "private": true,
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.js",
    "lint": "eslint src",
    "db:migrate": "node src/lib/migrate.js",
    "clean": "rm -rf coverage"
  },
  "dependencies": {
    "@apphub/platform-sdk": "workspace:*",
    "fastify": "^5.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "fastify-type-provider-zod": "^4.0.0",
    "node-cron": "^3.0.3",
    "pg": "^8.12.0",
    "ioredis": "^5.4.1",
    "zod": "^3.23.0",
    "pino": "^9.3.0",
    "pino-pretty": "^11.2.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "vitest": "^2.0.0",
    "@vitest/coverage-v8": "^2.0.0"
  }
}
