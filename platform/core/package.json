{
  "name": "@apphub/platform-core",
  "version": "0.1.0",
  "description": "Platform-core monolith — orchestrator that mounts all platform modules in a single Node process",
  "private": true,
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/bootstrap.js",
    "start": "node src/bootstrap.js",
    "test:unit": "vitest run --passWithNoTests",
    "test:integration": "vitest run --config vitest.integration.config.js --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "clean": "rm -rf coverage"
  },
  "dependencies": {
    "@apphub/platform-sdk": "workspace:*",
    "@apphub/platform-auth": "workspace:*",
    "@apphub/platform-notifications": "workspace:*",
    "@apphub/platform-payments": "workspace:*",
    "@apphub/platform-tenant-config": "workspace:*",
    "@apphub/platform-splitpay": "workspace:*",
    "@apphub/platform-storage": "workspace:*",
    "@apphub/platform-leads": "workspace:*",
    "@apphub/platform-donations": "workspace:*",
    "@apphub/platform-inquiries": "workspace:*",
    "@apphub/platform-verifactu": "workspace:*",
    "@apphub/platform-chat": "workspace:*",
    "@apphub/platform-tpv": "workspace:*",
    "@apphub/platform-commerce": "workspace:*",
    "@apphub/platform-orders": "workspace:*",
    "@apphub/platform-inventory": "workspace:*",
    "@apphub/platform-reviews": "workspace:*",
    "@apphub/platform-messaging": "workspace:*",
    "@apphub/platform-shipping": "workspace:*",
    "@apphub/platform-disputes": "workspace:*",
    "@apphub/platform-catalog": "workspace:*",
    "@apphub/platform-basket": "workspace:*",
    "@apphub/platform-menu": "workspace:*",
    "@apphub/platform-reservations": "workspace:*",
    "@apphub/platform-floor-plan": "workspace:*",
    "@apphub/platform-kds": "workspace:*",
    "@apphub/platform-pos": "workspace:*",
    "@apphub/platform-delivery-dispatch": "workspace:*",
    "@apphub/platform-services": "workspace:*",
    "@apphub/platform-resources": "workspace:*",
    "@apphub/platform-bookings": "workspace:*",
    "@apphub/platform-availability": "workspace:*",
    "@apphub/platform-intake-forms": "workspace:*",
    "@apphub/platform-telehealth": "workspace:*",
    "@apphub/platform-packages": "workspace:*",
    "@apphub/platform-practitioner-payouts": "workspace:*",
    "fastify": "^5.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/websocket": "^11.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "fastify-type-provider-zod": "^4.0.0",
    "pg": "^8.12.0",
    "ioredis": "^5.4.1",
    "zod": "^3.23.0",
    "pino": "^9.3.0",
    "pino-pretty": "^11.2.0"
  },
  "devDependencies": {
    "vitest": "^2.0.0",
    "@vitest/coverage-v8": "^2.0.0"
  }
}
